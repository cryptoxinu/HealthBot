# HealthBot Environment Variables
# Copy to .env and fill in values as needed.
# All variables are OPTIONAL — most settings use macOS Keychain or app.json.

# Vault passphrase (required for MCP server auto-startup)
# HEALTHBOT_PASSPHRASE=your_vault_passphrase

# Vault home directory (default: ~/.healthbot)
# HEALTHBOT_HOME=~/.healthbot

# Ollama settings (optional — Layer 3 PII anonymization)
# OLLAMA_MODEL=llama3.3:70b-instruct-q4_K_M
# OLLAMA_URL=http://localhost:11434

# Deployment mode (set during --setup: telegram, openclaw, or both)
# HEALTHBOT_MODE=telegram
